# Copy this to .env and fill in your AWS credentials

# AWS credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=your_region_here

# S3 bucket name
S3_BUCKET_NAME=your_bucket_name_here

# Snowflake credentials
SNOWFLAKE_ACCOUNT=your_account_name_here
SNOWFLAKE_USER=your_user_name_here
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_WAREHOUSE=your_warehouse_name_here
SNOWFLAKE_DATABASE=your_database_name_here

# API token
NSW_API_TOKEN=your_api_token_here